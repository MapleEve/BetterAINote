{
    "name": "betterainote",
    "version": "0.1.0",
    "private": true,
    "description": "Private self-hosted recording note workspace for source sync, recording import, and transcription",
    "author": "BetterAINote Contributors",
    "license": "SEE LICENSE IN LICENSE",
    "keywords": [
        "BetterAINote",
        "private-meeting-notes",
        "recording-import",
        "transcription",
        "TicNote",
        "DingTalk",
        "self-hosted",
        "meeting-notes",
        "voice-recorder",
        "Plaud",
        "ai",
        "nextjs",
        "typescript"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MapleEve/BetterAINote.git"
    },
    "homepage": "https://github.com/MapleEve/BetterAINote#readme",
    "bugs": {
        "url": "https://github.com/MapleEve/BetterAINote/issues"
    },
    "scripts": {
        "dev": "node scripts/dev-with-worker.mjs",
        "dev:web": "PORT=${PORT:-3001} WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=1 node scripts/run-with-local-env.mjs next dev --webpack",
        "dev:turbo": "PORT=${PORT:-3001} node scripts/run-with-local-env.mjs next dev",
        "build": "next build",
        "start": "PORT=${PORT:-3001} node scripts/run-with-local-env.mjs next start",
        "worker": "node scripts/run-with-local-env.mjs bun src/worker/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "e2e": "playwright test",
        "e2e:display": "playwright test e2e/display-settings-language.spec.ts",
        "type-check": "tsc --noEmit",
        "format-and-lint": "biome check .",
        "format-and-lint:fix": "biome check . --write",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "node scripts/run-with-local-env.mjs bun src/db/migrate.ts",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@google/genai": "^1.48.0",
        "@libsql/client": "^0.15.15",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@xenova/transformers": "^2.17.2",
        "better-auth": "^1.3.34",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "drizzle-orm": "^0.44.7",
        "lucide-react": "^0.554.0",
        "nanoid": "^5.1.6",
        "next": "16.0.7",
        "next-themes": "^0.4.6",
        "openai": "^6.9.1",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-hook-form": "^7.66.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0",
        "vitest": "^4.0.12",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.7",
        "@playwright/test": "^1.59.1",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "drizzle-kit": "^0.31.7",
        "tailwindcss": "^4",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5"
    }
}
