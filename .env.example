# Database
# Keep the SQLite file on local disk. Recordings can still be stored on a NAS mount.
DATABASE_PATH=./data/betterainote.db
# Optional sidecar DB for verbose word-level timing payloads.
# If omitted, BetterAINote derives ./data/betterainote-words.db next to DATABASE_PATH.
# TRANSCRIPT_WORDS_DATABASE_PATH=./data/betterainote-words.db

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
APP_URL=http://localhost:3001

# Encryption (for API keys)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# Local recordings path
# For Docker the container path is fixed to /app/audio; this host path is mounted there.
# For local dev you can point it at a writable directory such as ./storage.
LOCAL_STORAGE_PATH=./storage

# Optional Docker bind mounts
# APP_DATA_PATH=./data/app
# RECORDINGS_PATH=./data/recordings

# Worker poll tick in milliseconds.
# The worker checks which users are due for sync on this cadence.
SYNC_WORKER_TICK_MS=60000
